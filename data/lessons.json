      { "id": "s3-4", "english": "现在是下午五点。", "japanese": "いまごごごじです" },
      { "id": "s3-5", "english": "一、二、三、四、五。", "japanese": "いち、に、さん、よん、ご" },
      { "id": "s3-6", "english": "六、七、八、九、十。", "japanese": "ろく、なな、はち、きゅう、じゅう" }
    ]
  }
]
