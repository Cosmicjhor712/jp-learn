      { "id": "ichi", "japanese": "いち", "english": "一", "partOfSpeech": "数字" },
      { "id": "ni", "japanese": "に", "english": "二", "partOfSpeech": "数字" },
      { "id": "san", "japanese": "さん", "english": "三", "partOfSpeech": "数字" },
      { "id": "yon", "japanese": "よん", "english": "四", "partOfSpeech": "数字" },
      { "id": "go", "japanese": "ご", "english": "五", "partOfSpeech": "数字" },
      { "id": "roku", "japanese": "ろく", "english": "六", "partOfSpeech": "数字" },
      { "id": "nana", "japanese": "なな", "english": "七", "partOfSpeech": "数字" },
      { "id": "hachi", "japanese": "はち", "english": "八", "partOfSpeech": "数字" },
      { "id": "kyuu", "japanese": "きゅう", "english": "九", "partOfSpeech": "数字" },
      { "id": "juu", "japanese": "じゅう", "english": "十", "partOfSpeech": "数字" },
      { "id": "ji", "japanese": "じ", "english": "〜点（钟）", "partOfSpeech": "接尾語" },
      { "id": "fun", "japanese": "ふん", "english": "〜分（分钟）", "partOfSpeech": "接尾語" },
      { "id": "ima", "japanese": "いま", "english": "现在", "partOfSpeech": "名詞" },
      { "id": "nanji", "japanese": "なんじ", "english": "几点", "partOfSpeech": "代名詞" },
      { "id": "gozen", "japanese": "ごぜん", "english": "上午 (AM)", "partOfSpeech": "名詞" },
      { "id": "gogo", "japanese": "ごご", "english": "下午 (PM)", "partOfSpeech": "名詞" }
    ],
    "grammar": [
      {
        "pattern": "〜時〜分です",
        "explanation": "「现在是 X 点 Y 分」——じ 接在数字后表示「点」，ふん（或 ぷん）接在数字后表示「分」。注意：分 的发音会随前面数字变化：いっぷん(1分)、にふん(2分)、さんぷん(3分)、よんぷん(4分)…",
        "example": "いま さんじ じゅうごふん です。（现在是3点15分。）"
      },
      {
        "pattern": "今 〜時ですか",
        "explanation": "「现在几点？」——なんじ 是「几点」的意思。",
        "example": "いま なんじ ですか。（现在几点？）"
      }
    ],
    "sentences": [
      { "id": "s3-1", "english": "现在几点？", "japanese": "いまなんじですか", "grammarNote": "今 何時ですか" },
